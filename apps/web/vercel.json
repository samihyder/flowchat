{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/FlowChat/api/cron/marketing",
      "schedule": "* * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/FlowChat/sign-in",
      "permanent": false
    }
  ]
}
