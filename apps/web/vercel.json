{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/FlowChat/api/cron/marketing",
      "schedule": "* * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/FlowChat/sign-in",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/wa-automation",
      "destination": "https://wa-automation-neon.vercel.app/wa-automation"
    },
    {
      "source": "/wa-automation/:path*",
      "destination": "https://wa-automation-neon.vercel.app/wa-automation/:path*"
    },
    {
      "source": "/lead-monitor",
      "destination": "https://leadmonitor-psi.vercel.app/lead-monitor"
    },
    {
      "source": "/lead-monitor/:path*",
      "destination": "https://leadmonitor-psi.vercel.app/lead-monitor/:path*"
    }
  ],
  "headers": [
    {
      "source": "/wa-automation",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-store, no-cache, must-revalidate"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/wa-automation/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-store, no-cache, must-revalidate"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
