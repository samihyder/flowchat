{
  "name": "flowchat",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:studio": "pnpm --filter @flowchat/db studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
