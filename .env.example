# ─── Local development ─────────────────────────────────────────────────────
# Copy to .env and fill in values

# PostgreSQL — FlowChat Phase 1 uses Supabase (postgres.js / drizzle-orm/postgres-js)
# Pooler (app runtime, port 6543) and session/direct (migrations, port 5432):
DATABASE_URL=postgresql://postgres.YOUR_REF:[PASSWORD]@aws-1-REGION.pooler.supabase.com:6543/postgres?sslmode=require
DIRECT_URL=postgresql://postgres.YOUR_REF:[PASSWORD]@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# FlowChat Supabase project (Phase 1 target)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-db-password

# Legacy Neon (rollback only — HTTP neon() client removed)
# DATABASE_URL=postgresql://user:password@ep-xxx.us-west-2.aws.neon.tech/neondb?sslmode=require

# API (services/api) — local
JWT_SECRET=replace-with-at-least-32-random-characters
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3200
WEB_APP_URL=http://localhost:3200
API_PUBLIC_URL=http://localhost:3001

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web (apps/web) — local Next.js API routes live at :3200/api (not :3001)
# Copy DATABASE_URL into apps/web/.env.local for marketing API routes.
NEXT_PUBLIC_API_URL=http://localhost:3200/api
NEXT_PUBLIC_WS_URL=ws://localhost:3002

# Local dev: leave NEXT_PUBLIC_BASE_PATH unset (routes at http://localhost:3100/sign-in).
# Production subpath only — see docs/SUBPATH_DEPLOYMENT.md:
#   NEXT_PUBLIC_BASE_PATH=/FlowChat

# WS (services/ws) — local
WS_PORT=3002
REDIS_URL=redis://localhost:6379

# ─── Production (reference — set in platform dashboards, not in repo) ────────
#
# VERCEL (apps/web):
#   NEXT_PUBLIC_API_URL=https://<api>.up.railway.app
#   NEXT_PUBLIC_WS_URL=wss://<ws>.up.railway.app
#
# RAILWAY — API (services/api):
#   CORS_ORIGIN=https://<app>.vercel.app,https://www.digitalbrandcast.com
#
# VERCEL — Web app (apps/web) — subpath on custom domain (optional):
#   NEXT_PUBLIC_BASE_PATH=/FlowChat
#   NEXT_PUBLIC_WEB_APP_URL=https://www.digitalbrandcast.com/FlowChat
#   WEB_APP_URL=https://www.digitalbrandcast.com/FlowChat
#   See docs/SUBPATH_DEPLOYMENT.md
#
#   JWT_SECRET=<32+-char-secret>
#   NODE_ENV=production
#   CORS_ORIGIN=https://<app>.vercel.app
#   WEB_APP_URL=https://<app>.vercel.app
#   API_PUBLIC_URL=https://<api>.up.railway.app
#
# VERCEL — Web app (apps/web) — required for real-time chat:
#   REDIS_URL=<same Railway Redis URL as WS service>
#   NEXT_PUBLIC_WS_URL=wss://<ws>.up.railway.app
#
# RAILWAY — WS (services/ws):
#   DATABASE_URL=<neon-pooler-url>
#   REDIS_URL=${{Redis.REDIS_URL}}
#   NODE_ENV=production
#
# RAILWAY — Worker (services/worker):
#   REDIS_URL=${{Redis.REDIS_URL}}
#   WEB_APP_URL=https://<app>.vercel.app
#   CRON_SECRET=<same value as Vercel apps/web>
#   NODE_ENV=production
#
# VERCEL — Web app (apps/web) — marketing cron auth:
#   CRON_SECRET=<random 32-byte hex>
#   RESEND_WEBHOOK_SECRET=whsec_…   # required for /api/webhooks/resend (platform Resend)
#   DATABASE_URL=<neon-pooler-url>
#   CREDENTIALS_ENCRYPTION_KEY=<openssl rand -hex 32>  # Preview + Production (required to save API keys)
#   R2_ACCOUNT_ID=
#   R2_ACCESS_KEY_ID=
#   R2_SECRET_ACCESS_KEY=
#   R2_BUCKET_NAME=flowchat-production
#   R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
#
# Mutex ecosystem (FlowChat parent + child apps):
#   MUTEX_ECOSYSTEM_SSO_SECRET=<openssl rand -hex 32>  # shared across FlowChat, wa-automation, Lead Monitor
#   NEXT_PUBLIC_SITE_URL=https://www.digitalbrandcast.com
#   WHATSAPP_CRM_BASE_URL=https://www.digitalbrandcast.com/wa-automation
